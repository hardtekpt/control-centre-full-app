{
  "name": "control-centre-full-app",
  "version": "0.1.0",
  "description": "Electron + React tray flyout for Arctis Nova + Sonar control",
  "main": ".electron-build/electron/main.js",
  "author": "local",
  "license": "MIT",
  "scripts": {
    "clean:electron-build": "node -e \"require('node:fs').rmSync('.electron-build', { recursive: true, force: true })\"",
    "free:dev-port": "node scripts/free-dev-port.cjs 5180",
    "dev": "npm run clean:electron-build && npm run free:dev-port && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5180 .electron-build/electron/main.js .electron-build/electron/preload.js .electron-build/shared/ipc.js .electron-build/electron/ipc/registerCoreHandlers.js .electron-build/electron/ipc/settingsHandlers.js .electron-build/electron/ipc/mixerHandlers.js .electron-build/electron/ipc/ddcHandlers.js && node scripts/dev-electron.cjs",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hensm/ddcci": "file:vendor/node-ddcci",
    "node-hid": "^3.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.8",
    "sass": "^1.83.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.control.centre",
    "productName": "Control Centre",
    "asarUnpack": [
      "scripts/**",
      "vendor/**"
    ],
    "files": [
      "dist/**",
      ".electron-build/**",
      "electron/assets/**",
      "scripts/**",
      "vendor/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "directories": {
      "buildResources": "build"
    }
  }
}
