{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "src/renderer/src",
    "src/shared",
    "src/renderer/vite.config.ts"
  ]
}
